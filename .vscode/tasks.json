{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Publish Jellyfin Plugin (Release)",
            "command": "dotnet",
            "type": "process",
            "args": [
                "publish",
                "-c",
                "Release"
            ],
            "problemMatcher": "$msCompile",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "detail": "Compiles the WatchPartySync plugin into a Release DLL ready for Jellyfin."
        }
    ]
}